<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Degradado de fondo (verde institucional) -->
    <item>
        <shape>
            <gradient
                android:startColor="@color/primary"
                android:endColor="@color/primary_dark"
                android:angle="135" />
        </shape>
    </item>

    <!-- Onda decorativa en la parte inferior (dentro de la pantalla) -->
    <item android:top="100dp">
        <shape>
            <solid android:color="@color/background_login" />
            <corners android:topLeftRadius="60dp" android:topRightRadius="60dp" />
        </shape>
    </item>

</layer-list>