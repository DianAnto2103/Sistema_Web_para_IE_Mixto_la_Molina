<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_school"
    android:fillViewport="true"
    tools:context=".ui.alumno.detallecurso.DetalleCursoFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ========== HEADER ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_back"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/primary_dark" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Detalle del Curso"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/primary_dark"
                android:layout_marginStart="8dp" />

        </LinearLayout>

        <!-- ========== PROGRESS BAR ========== -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:layout_marginTop="32dp"
            android:visibility="gone" />

        <!-- ========== TARJETA INFORMACIÓN CURSO ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tvNombreCurso"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Matemáticas"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tvDocente"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Prof. Juan Pérez"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <!-- Horario -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_time"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvHorario"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lunes 3:00 PM"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Aula -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_section"
                            android:layout_marginEnd="8dp"
                            app:tint="@color/text_secondary" />

                        <TextView
                            android:id="@+id/tvAula"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aula 201"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvDescripcion"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Curso de álgebra y geometría"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:layout_marginTop="8dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ========== PROMEDIO ========== -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Promedio: "
                    android:textColor="@color/text_secondary"
                    android:textSize="16sp" />

                <TextView
                    android:id="@+id/tvPromedio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="16.5"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/tvEstadoPromedio"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Aprobado"
                    android:textSize="14sp"
                    android:textColor="@color/success"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_estado_disponible"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ========== BIMESTRES ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calificaciones por Bimestre"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/primary_dark"
            android:layout_marginBottom="12dp" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/white"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:id="@+id/layoutBimestres"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Items se agregarán dinámicamente -->

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- ========== BOTÓN DE ACCIÓN ========== -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnVerRendimiento"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Ver Rendimiento"
            android:textSize="14sp"
            app:cornerRadius="8dp"
            app:backgroundTint="@color/primary" />

    </LinearLayout>
</ScrollView>