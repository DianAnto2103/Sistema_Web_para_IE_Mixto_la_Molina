<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/loginFragment">

    <!-- ==================== LOGIN ==================== -->
    <fragment
        android:id="@+id/loginFragment"
        android:name="com.example.mixtotrackmobile.ui.login.LoginFragment"
        android:label="Iniciar Sesión"
        tools:layout="@layout/fragment_login">

        <action
            android:id="@+id/action_login_to_menuAlumno"
            app:destination="@id/alumno_navigation"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />

        <action
            android:id="@+id/action_login_to_menuDocente"
            app:destination="@id/docente_navigation"
            app:popUpTo="@id/loginFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- ==================== MAIN ACTIVITY ==================== -->
    <activity
        android:id="@+id/mainActivity"
        android:name="com.example.mixtotrackmobile.ui.main.MainActivity"
        android:label="Mixto Track" />

    <!-- ==================== NAVEGACIÓN ALUMNO ==================== -->
    <navigation
        android:id="@+id/alumno_navigation"
        app:startDestination="@id/menuAlumnoFragment">

        <!-- Menú Alumno -->
        <fragment
            android:id="@+id/menuAlumnoFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.menu.MenuAlumnoFragment"
            android:label="Menú Alumno"
            tools:layout="@layout/fragment_menu_alumno">

            <action
                android:id="@+id/action_menuAlumno_to_login"
                app:destination="@id/loginFragment"
                app:popUpTo="@id/loginFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_menuAlumno_to_perfil"
                app:destination="@id/perfilFragment" />
            <action
                android:id="@+id/action_menuAlumno_to_notificaciones"
                app:destination="@id/notificacionesFragment" />
            <action
                android:id="@+id/action_menuAlumno_to_solicitarTaller"
                app:destination="@id/solicitarTallerFragment" />
            <action
                android:id="@+id/action_menuAlumno_to_grupoEstudio"
                app:destination="@id/grupoEstudioFragment" />
            <action
                android:id="@+id/action_menuAlumno_to_misCursos"
                app:destination="@id/misCursosFragment" />
        </fragment>

        <!-- ✅ Perfil (dentro de alumno) -->
        <fragment
            android:id="@+id/perfilFragment"
            android:name="com.example.mixtotrackmobile.ui.common.perfil.PerfilFragment"
            android:label="Mi Perfil"
            tools:layout="@layout/fragment_perfil" />

        <!-- ✅ Notificaciones (dentro de alumno) -->
        <fragment
            android:id="@+id/notificacionesFragment"
            android:name="com.example.mixtotrackmobile.ui.common.notificaciones.NotificacionesFragment"
            android:label="Notificaciones"
            tools:layout="@layout/fragment_notificaciones" />

        <!-- Solicitar Taller -->
        <fragment
            android:id="@+id/solicitarTallerFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.solicitartaller.SolicitarTallerFragment"
            android:label="Solicitar Taller"
            tools:layout="@layout/fragment_solicitar_taller">

            <action
                android:id="@+id/action_solicitarTaller_to_misTalleres"
                app:destination="@id/misTalleresFragment" />
            <action
                android:id="@+id/action_solicitarTaller_to_horarioDocente"
                app:destination="@id/horarioDocenteFragment" />
            <action
                android:id="@+id/action_solicitarTaller_to_menuAlumno"
                app:destination="@id/menuAlumnoFragment"
                app:popUpTo="@id/menuAlumnoFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Horario Docente -->
        <fragment
            android:id="@+id/horarioDocenteFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.solicitartaller.horariodocente.HorarioDocenteFragment"
            android:label="Horario del Docente"
            tools:layout="@layout/fragment_horario_docente">
            <action
                android:id="@+id/action_horarioDocente_to_solicitarTaller"
                app:destination="@id/solicitarTallerFragment"
                app:popUpTo="@id/solicitarTallerFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Grupo Estudio -->
        <fragment
            android:id="@+id/grupoEstudioFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.grupoestudio.GrupoEstudioFragment"
            android:label="Grupo de Estudio"
            tools:layout="@layout/fragment_grupo_estudio">
            <action
                android:id="@+id/action_grupoEstudio_to_menuAlumno"
                app:destination="@id/menuAlumnoFragment"
                app:popUpTo="@id/menuAlumnoFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Mis Cursos -->
        <fragment
            android:id="@+id/misCursosFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.miscursos.MisCursosFragment"
            android:label="Mis Cursos"
            tools:layout="@layout/fragment_mis_cursos">
            <action
                android:id="@+id/action_misCursos_to_rendimientoAcademico"
                app:destination="@id/rendimientoAcademicoFragment" />
            <action
                android:id="@+id/action_misCursos_to_menuAlumno"
                app:destination="@id/menuAlumnoFragment"
                app:popUpTo="@id/menuAlumnoFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_misCursos_to_detalleCurso"
                app:destination="@id/detalleCursoFragment" />
        </fragment>

        <!-- Detalle Curso -->
        <fragment
            android:id="@+id/detalleCursoFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.detallecurso.DetalleCursoFragment"
            android:label="Detalle del Curso"
            tools:layout="@layout/fragment_detalle_curso">
            <action
                android:id="@+id/action_detalleCurso_to_rendimientoAcademico"
                app:destination="@id/rendimientoAcademicoFragment" />
            <action
                android:id="@+id/action_detalleCurso_to_misCursos"
                app:destination="@id/misCursosFragment"
                app:popUpTo="@id/misCursosFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Rendimiento Académico -->
        <fragment
            android:id="@+id/rendimientoAcademicoFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.miscursos.rendimientoacademico.RendimientoAcademicoFragment"
            android:label="Rendimiento Académico"
            tools:layout="@layout/fragment_rendimiento_academico">
            <action
                android:id="@+id/action_rendimiento_to_misCursos"
                app:destination="@id/misCursosFragment"
                app:popUpTo="@id/misCursosFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Mis Talleres -->
        <fragment
            android:id="@+id/misTalleresFragment"
            android:name="com.example.mixtotrackmobile.ui.alumno.mis_talleres.MisTalleresFragment"
            android:label="Mis Talleres"
            tools:layout="@layout/fragment_mis_talleres">
            <action
                android:id="@+id/action_misTalleres_to_solicitarTaller"
                app:destination="@id/solicitarTallerFragment"
                app:popUpTo="@id/solicitarTallerFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_misTalleres_to_menuAlumno"
                app:destination="@id/menuAlumnoFragment"
                app:popUpTo="@id/menuAlumnoFragment"
                app:popUpToInclusive="true" />
        </fragment>

    </navigation>

    <!-- ==================== NAVEGACIÓN DOCENTE ==================== -->
    <navigation
        android:id="@+id/docente_navigation"
        app:startDestination="@id/menuDocenteFragment">

        <!-- Menú Docente -->
        <fragment
            android:id="@+id/menuDocenteFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.menu.MenuDocenteFragment"
            android:label="Menú Docente"
            tools:layout="@layout/fragment_menu_docente">

            <action
                android:id="@+id/action_menuDocente_to_login"
                app:destination="@id/loginFragment"
                app:popUpTo="@id/loginFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_menuDocente_to_perfil"
                app:destination="@id/perfilFragment" />
            <action
                android:id="@+id/action_menuDocente_to_notificaciones"
                app:destination="@id/notificacionesFragment" />
            <action
                android:id="@+id/action_menuDocente_to_cursos"
                app:destination="@id/cursosFragment" />
            <action
                android:id="@+id/action_menuDocente_to_talleres"
                app:destination="@id/talleresFragment" />
            <action
                android:id="@+id/action_menuDocente_to_busquedaAlumno"
                app:destination="@id/busquedaAlumnoFragment" />
            <action
                android:id="@+id/action_menuDocente_to_registrarCalificacion"
                app:destination="@id/registrarCalificacionFragment" />
            <action
                android:id="@+id/action_menuDocente_to_detalleCursoDocente"
                app:destination="@id/detalleCursoDocenteFragment" />
            <action
                android:id="@+id/action_menuDocente_to_horarios"
                app:destination="@id/horariosFragment" />
        </fragment>

        <!-- ✅ Perfil (dentro de docente) -->
        <fragment
            android:id="@+id/perfilFragment"
            android:name="com.example.mixtotrackmobile.ui.common.perfil.PerfilFragment"
            android:label="Mi Perfil"
            tools:layout="@layout/fragment_perfil" />

        <!-- ✅ Notificaciones (dentro de docente) -->
        <fragment
            android:id="@+id/notificacionesFragment"
            android:name="com.example.mixtotrackmobile.ui.common.notificaciones.NotificacionesFragment"
            android:label="Notificaciones"
            tools:layout="@layout/fragment_notificaciones" />

        <!-- Cursos -->
        <fragment
            android:id="@+id/cursosFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.cursos.CursosFragment"
            android:label="Mis Cursos"
            tools:layout="@layout/fragment_cursos">
            <action
                android:id="@+id/action_cursos_to_busquedaAlumno"
                app:destination="@id/busquedaAlumnoFragment" />
            <action
                android:id="@+id/action_cursos_to_detalleCursoDocente"
                app:destination="@id/detalleCursoDocenteFragment" />
            <action
                android:id="@+id/action_cursos_to_menuDocente"
                app:destination="@id/menuDocenteFragment"
                app:popUpTo="@id/menuDocenteFragment"
                app:popUpToInclusive="true" />

            <action
                android:id="@+id/action_cursos_to_registrarCalificacion"
                app:destination="@id/registrarCalificacionFragment" />
        </fragment>

        <!-- Búsqueda Alumno -->
        <fragment
            android:id="@+id/busquedaAlumnoFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.cursos.busquedaalumno.BusquedaAlumnoFragment"
            android:label="Buscar Alumno"
            tools:layout="@layout/fragment_busqueda_alumno">
            <action
                android:id="@+id/action_busquedaAlumno_to_registrarCalificacion"
                app:destination="@id/registrarCalificacionFragment" />
            <action
                android:id="@+id/action_busquedaAlumno_to_cursos"
                app:destination="@id/cursosFragment"
                app:popUpTo="@id/cursosFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_busquedaAlumno_to_menuDocente"
                app:destination="@id/menuDocenteFragment"
                app:popUpTo="@id/menuDocenteFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Registrar Calificación -->
        <fragment
            android:id="@+id/registrarCalificacionFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.cursos.registrarcalificacion.RegistrarCalificacionFragment"
            android:label="Registrar Calificación"
            tools:layout="@layout/fragment_registrar_calificacion">
            <action
                android:id="@+id/action_registrarCalificacion_to_busquedaAlumno"
                app:destination="@id/busquedaAlumnoFragment"
                app:popUpTo="@id/busquedaAlumnoFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_registrarCalificacion_to_menuDocente"
                app:destination="@id/menuDocenteFragment"
                app:popUpTo="@id/menuDocenteFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Detalle Curso Docente -->
        <fragment
            android:id="@+id/detalleCursoDocenteFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.cursos.detallecurso.DetalleCursoDocenteFragment"
            android:label="Detalle del Curso"
            tools:layout="@layout/fragment_detalle_curso_docente">
            <action
                android:id="@+id/action_detalleCursoDocente_to_registrarCalificacion"
                app:destination="@id/registrarCalificacionFragment" />
            <action
                android:id="@+id/action_detalleCursoDocente_to_cursos"
                app:destination="@id/cursosFragment"
                app:popUpTo="@id/cursosFragment"
                app:popUpToInclusive="true" />
            <action
                android:id="@+id/action_detalleCursoDocente_to_menuDocente"
                app:destination="@id/menuDocenteFragment"
                app:popUpTo="@id/menuDocenteFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Talleres -->
        <fragment
            android:id="@+id/talleresFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.talleres.TalleresFragment"
            android:label="Talleres"
            tools:layout="@layout/fragment_talleres">
            <action
                android:id="@+id/action_talleres_to_menuDocente"
                app:destination="@id/menuDocenteFragment"
                app:popUpTo="@id/menuDocenteFragment"
                app:popUpToInclusive="true" />
        </fragment>

        <!-- Horarios -->
        <fragment
            android:id="@+id/horariosFragment"
            android:name="com.example.mixtotrackmobile.ui.docente.horarios.HorariosFragment"
            android:label="Mis Horarios"
            tools:layout="@layout/fragment_horarios">
            <action
                android:id="@+id/action_horarios_to_menuDocente"
                app:destination="@id/menuDocenteFragment"
                app:popUpTo="@id/menuDocenteFragment"
                app:popUpToInclusive="true" />
        </fragment>

    </navigation>

</navigation>