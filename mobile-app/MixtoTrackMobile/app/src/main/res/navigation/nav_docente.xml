<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/nav_docente"
    app:startDestination="@id/menuDocenteFragment">

    <!-- ====== MENÚ PRINCIPAL ====== -->
    <fragment
        android:id="@+id/menuDocenteFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.menu.MenuDocenteFragment"
        android:label="Menú Docente"
        tools:layout="@layout/fragment_menu_docente">

        <action
            android:id="@+id/action_menuDocente_to_cursos"
            app:destination="@id/cursosFragment" />

        <action
            android:id="@+id/action_menuDocente_to_buscarAlumnos"
            app:destination="@id/busquedaAlumnoFragment" />

        <action
            android:id="@+id/action_menuDocente_to_registrarCalificacion"
            app:destination="@id/registrarCalificacionFragment" />

        <action
            android:id="@+id/action_menuDocente_to_horarios"
            app:destination="@id/horariosFragment" />

        <action
            android:id="@+id/action_menuDocente_to_perfil"
            app:destination="@id/perfilDocenteFragment" />

        <action
            android:id="@+id/action_menuDocente_to_talleres"
            app:destination="@id/talleresFragment" />

    </fragment>

    <!-- ====== FRAGMENTOS DESTINO ====== -->

    <!-- Mis Cursos -->
    <fragment
        android:id="@+id/cursosFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.cursos.CursosFragment"
        android:label="Mis Cursos"
        tools:layout="@layout/fragment_cursos" />

    <!-- Buscar Alumnos -->
    <fragment
        android:id="@+id/busquedaAlumnoFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.busquedaalumno.BusquedaAlumnoFragment"
        android:label="Buscar Alumnos"
        tools:layout="@layout/fragment_busqueda_alumno" />

    <!-- Registrar Calificaciones -->
    <fragment
        android:id="@+id/registrarCalificacionFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.registrarcalificacion.RegistrarCalificacionFragment"
        android:label="Registrar Calificaciones"
        tools:layout="@layout/fragment_registrar_calificacion" />

    <!-- Mis Horarios -->
    <fragment
        android:id="@+id/horariosFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.horarios.HorariosFragment"
        android:label="Mis Horarios"
        tools:layout="@layout/fragment_horario_docente" />

    <!-- Mi Perfil -->
    <fragment
        android:id="@+id/perfilDocenteFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.perfil.PerfilDocenteFragment"
        android:label="Mi Perfil"
        tools:layout="@layout/fragment_perfil" />

    <!-- Talleres -->
    <fragment
        android:id="@+id/talleresFragment"
        android:name="com.example.mixtotrackmobile.ui.docente.talleres.TalleresFragment"
        android:label="Talleres"
        tools:layout="@layout/fragment_talleres" />

</navigation>